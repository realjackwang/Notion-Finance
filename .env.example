# Notion integration token
NOTION_TOKEN=your_notion_api_key_here

# 招商银行接口签名密钥
CMB_AUTH_KEY=your_cmb_auth_key_here
# 招商银行财富历史值接口密钥 (用于cfweb.paas.cmbchina.com的getSAValueByPageOrDate接口)
CMB_VALUE_AUTH_KEY=your_cmb_value_auth_key_here

# Notion database IDs
DATABASE_ID_ASSETS=your_assets_database_id_here
DATABASE_ID_HISTORY=your_history_database_id_here
DATABASE_ID_TRANSACTIONS=your_transactions_database_id_here
DATABASE_ID_DCA_LOGS=your_dca_log_database_id_here

# Notion 仪表盘块 ID
NOTION_BLOCK_TOTAL_ASSET_ID=your_total_asset_block_id_here
NOTION_BLOCK_CUMULATIVE_PROFIT_ID=your_cumulative_profit_block_id_here
NOTION_BLOCK_DAILY_PROFIT_ID=your_daily_profit_block_id_here
NOTION_BLOCK_MAX_DRAWDOWN_ID=your_max_drawdown_block_id_here
NOTION_BLOCK_ANNUAL_RETURN_ID=your_annual_return_block_id_here